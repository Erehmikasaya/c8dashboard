# ══════════════════════════════════════════════════════
#  C8 Dashboard — Environment Variables (Vercel)
# ══════════════════════════════════════════════════════
# Set these in Vercel Dashboard → Settings → Environment Variables

# ── Upstash Redis (FREE — https://upstash.com) ──
# Create a free Redis database and copy REST credentials
UPSTASH_REDIS_REST_URL=https://YOUR_REDIS.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── API Key (bot push authentication) ──
# Must match the api_key in config.json on each VPS
API_KEY=c8bot-super-secret-key-2026

# ── Basic Auth (browser access protection) ──
# Leave empty to disable (NOT recommended)
BASIC_USER=admin
BASIC_PASS=your-strong-password-here

# ── Optional: Telegram Alerts ──
# Sends alerts when VPS goes offline
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id
